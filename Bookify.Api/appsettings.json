{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://bookify-seq:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": ""
  },
  "MediatR": {
    "LicenseKey": ""
  },
  "Authentication": {
    "Audience": "",
    "MetadataUrl": "",
    "RequireHttpsMetadata": false,
    "Issuer": ""
  },
  "Keycloak": {
    "AdminUrl": "",
    "TokenUrl": "",
    "AdminClientId": "",
    "AdminClientSecret": "",
    "AuthClientId": "",
    "AuthClientSecret": ""
  }
}